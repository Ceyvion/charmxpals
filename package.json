{
  "name": "charmxpals",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/dev-guard.mjs",
    "dev:plaza": "node ./scripts/dev-plaza.mjs",
    "dev:webpack": "node ./scripts/dev-guard.mjs --no-turbo",
    "dev:safe": "NEXT_PUBLIC_DISABLE_3D=1 node ./scripts/dev-guard.mjs --no-turbo",
    "build": "rm -rf .next && node ./node_modules/next/dist/bin/next build",
    "start": "node ./scripts/start-guard.mjs",
    "start:kill-dev": "node ./scripts/start-guard.mjs --kill-dev",
    "start:force": "node ./scripts/start-guard.mjs --force",
    "lint": "eslint src server scripts next.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "mmo:server": "npx ts-node --transpile-only --project tsconfig.scripts.json server/mmo/server.ts",
    "import:cxp": "ts-node --transpile-only scripts/import-cxp.ts",
    "imagegen:manifests": "npx ts-node --transpile-only --project tsconfig.scripts.json scripts/build-imagegen-manifests.ts",
    "imagegen:stage": "npx ts-node --transpile-only --project tsconfig.scripts.json scripts/stage-image-assets.ts",
    "assets:optimize": "python3 scripts/optimize-assets.py",
    "orchestrator": "node scripts/orchestrator.mjs",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.7",
    "@react-three/fiber": "^8.16.2",
    "@upstash/redis": "^1.31.4",
    "animejs": "^3.2.1",
    "csv-parse": "^5.5.6",
    "framer-motion": "^10.12.16",
    "jsqr": "^1.4.0",
    "native-url": "^0.3.4",
    "next": "15.5.19",
    "next-auth": "4.24.14",
    "phaser": "^3.90.0",
    "react": "^18",
    "react-dom": "^18",
    "three": "^0.165.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "2.1.4",
    "@next/eslint-plugin-next": "15.5.19",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/animejs": "^3.1.7",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "autoprefixer": "^10.4.21",
    "brace-expansion": "1.1.15",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-react-hooks": "5.2.0",
    "postcss": "8.5.10",
    "tailwindcss": "4.3.0",
    "ts-node": "^10.9.1",
    "typescript": "^5",
    "vitest": "4.1.8"
  },
  "overrides": {
    "eslint": {
      "minimatch": {
        "brace-expansion": "1.1.15"
      }
    },
    "next": {
      "postcss": "8.5.10"
    },
    "next-auth": {
      "uuid": "11.1.1"
    },
    "eslint-plugin-react": {
      "resolve": "1.22.12"
    },
    "@tailwindcss/oxide": {
      "tar": "7.5.16"
    },
    "ts-node": {
      "diff": "4.0.4"
    }
  }
}
